# =============================================================================
# Beleqet Backend — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://beleqet_user:your_password@localhost:5432/beleqet_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

CHAPA_SECRET_KEY=CHASECK_TEST-...
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...
CHAPA_WEBHOOK_SECRET=your_webhook_secret
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@beleqet.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Beleqet <noreply@beleqet.com>

BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_board_password
